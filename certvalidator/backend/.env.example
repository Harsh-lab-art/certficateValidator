# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://certval:certval@localhost:5432/certvalidator

# ── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_32_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── ML Models ───────────────────────────────────────────────────────────────
CHECKPOINT_DIR=ml/models/checkpoints

# ── Storage ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=20

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
